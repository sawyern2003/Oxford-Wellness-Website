{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/robots.txt", "dest": "/api/robots" },
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/wellness", "status": 301, "headers": { "Location": "/womens-health-oxford" } },
    { "src": "/lip-filler", "status": 301, "headers": { "Location": "/treatments/lip-fillers-oxford" } },
    { "src": "/filler-dissolving", "status": 301, "headers": { "Location": "/treatments/filler-dissolving-oxford" } },
    { "src": "/excessive-sweating-treatment", "status": 301, "headers": { "Location": "/treatments/excessive-sweating-treatment-oxford" } },
    { "src": "/news-and-specials", "status": 301, "headers": { "Location": "/blog" } },
    { "src": "/vitamin-b12-injection", "status": 301, "headers": { "Location": "/treatments/vitamin-b12-injection-oxford" } },
    { "src": "/downturned-mouth-treatment", "status": 301, "headers": { "Location": "/treatments/dermal-fillers-oxford" } },
    { "src": "/perfect-peel", "status": 301, "headers": { "Location": "/treatments/chemical-peels-oxford" } },
    { "src": "/bunny-lines-treatment", "status": 301, "headers": { "Location": "/treatments/anti-wrinkle-injections-oxford" } },
    { "src": "/blog/are-facials-really-important", "status": 301, "headers": { "Location": "/blog" } },
    { "src": "/medical-form-completion-appointment", "status": 301, "headers": { "Location": "/treatments/medical-form-completion-oxford" } },
    { "src": "/hyaluronic-acid-skinbooster", "status": 301, "headers": { "Location": "/treatments/skin-boosters-oxford" } },
    { "src": "/about-us", "status": 301, "headers": { "Location": "/about" } },
    { "src": "/dimpled-chin-treatment", "status": 301, "headers": { "Location": "/treatments/anti-wrinkle-injections-oxford" } },
    { "src": "/body", "status": 301, "headers": { "Location": "/treatments/forma-plus-body-contouring-oxford" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
